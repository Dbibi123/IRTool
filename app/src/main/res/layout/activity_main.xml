<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ========== 顶部标题栏 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <!-- 左侧占位（保持标题居中） -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cultraview Remote"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <!-- 右侧 info 图标 -->
            <TextView
                android:id="@+id/tv_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="ⓘ"
                android:textSize="22sp"
                android:textColor="#888888"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- ========== 手动发送卡片 ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEC遥控器码值"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5"
                    android:paddingBottom="12dp"/>

                <!-- 头码 + 码值 输入行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="头码"
                        android:textSize="15sp"
                        android:textColor="#555555"
                        android:paddingRight="8dp"/>

                    <EditText
                        android:id="@+id/et_head_code"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_bg"
                        android:gravity="center"
                        android:hint="例: 41FB"
                        android:inputType="text"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="码值"
                        android:textSize="15sp"
                        android:textColor="#555555"
                        android:paddingHorizontal="8dp"/>

                    <EditText
                        android:id="@+id/et_command"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_bg"
                        android:gravity="center"
                        android:hint="例: DB"
                        android:inputType="text"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:textColor="#000000"/>
                </LinearLayout>

                <!-- 自动计算显示 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp">

                    <TextView
                        android:id="@+id/tv_complement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="互补码：0x24 "
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/tv_full_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="完整码值：0x24DBFB41"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:fontFamily="monospace"
                        android:paddingTop="4dp"/>
                </LinearLayout>

                <!-- 发送按钮 -->
                <Button
                    android:id="@+id/btn_send"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="发送码值"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1E88E5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 快捷发送卡片（6键） ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快捷发送（短按发送 / 长按编辑）"
                    android:textSize="16sp"
                    android:textColor="#FF6F00"
                    android:textStyle="bold"
                    android:paddingBottom="12dp"/>

                <!-- 6 个按键 2 行 3 列 -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="2"
                    android:alignmentMode="alignBounds"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/btn_preset_0"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/oval_button_bg"
                        android:text="未设置"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"/>

                    <Button
                        android:id="@+id/btn_preset_1"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/oval_button_bg"
                        android:text="未设置"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"/>

                    <Button
                        android:id="@+id/btn_preset_2"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/oval_button_bg"
                        android:text="未设置"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"/>

                    <Button
                        android:id="@+id/btn_preset_3"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/oval_button_bg"
                        android:text="未设置"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"/>

                    <Button
                        android:id="@+id/btn_preset_4"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/oval_button_bg"
                        android:text="未设置"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"/>

                    <Button
                        android:id="@+id/btn_preset_5"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/oval_button_bg"
                        android:text="未设置"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== 日志卡片 ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            android:radius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="日志"
                    android:textSize="16sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:paddingBottom="8dp"/>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="#F5F5F5"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无记录"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="3dp"/>
                </ScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
